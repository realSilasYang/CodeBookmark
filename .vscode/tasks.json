{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build extension",
			"type": "npm",
			"script": "compile",
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"clear": true
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch extension",
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated"
			}
		}
	]
}
