{
  "name": "codebookmark",
  "displayName": "Code Bookmarks",
  "description": "一款强大的代码书签管理插件，能够让你在 VS Code 中高效地标记、导航和管理代码跳转。",
  "version": "1.0.0",
  "publisher": "阳熙来",
  "author": "阳熙来",
  "private": true,
  "license": "MIT",
  "icon": "resources/bookmark_logo.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "generate-package-json": "node generate-package-json.js",
    "build:dev": "npm run compile && cross-env BUILD_ENV=Dev npm run generate-package-json",
    "build:prod": "npm run compile && cross-env npm run generate-package-json",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node generate-package-json.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "globals": "^15.11.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {},
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebookmark",
          "title": "代码书签",
          "icon": "resources/bookmark.svg"
        }
      ]
    },
    "views": {
      "codebookmark": [
        {
          "id": "codebookmarkTreeView",
          "name": "代码书签",
          "icon": "resources/bookmark.svg",
          "contextualTitle": "代码书签"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codebookmarkTreeView",
        "contents": "暂无书签，按 [Ctrl+B] 添加\n\n[查看使用说明](command:codebookmark.openHelp)",
        "when": "bookmarks.var.bookmark.loaded && !bookmarks.var.bookmark.hasBookmark"
      }
    ],
    "commands": [
      {
        "command": "codebookmark.toggleBookmark",
        "title": "添加/删除书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.forceAddBookmark",
        "title": "强制添加书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.forceDeleteBookmark",
        "title": "强制删除书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.deleteBookmark",
        "title": "删除",
        "icon": "$(trash)"
      },
      {
        "command": "codebookmark.editBookmark",
        "title": "编辑标签",
        "icon": "$(edit)"
      },
      {
        "command": "codebookmark.editBookmark.editLabel",
        "title": "重命名书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.editBookmark.updatePosOnly",
        "title": "更新书签位置到当前光标处（保留标签）",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.editBookmark.updatePosAndRename",
        "title": "更新书签位置到当前光标处（重命名标签）",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.editBookmark.changeIcon",
        "title": "自定义书签图标",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.editBookmark.restoreDefaultIcon",
        "title": "恢复默认图标",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.renameBookmark",
        "title": "重命名书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.pinView",
        "title": "设为新书签上级节点",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codebookmark.unpinView",
        "title": "取消新书签上级节点",
        "icon": "$(folder)"
      },
      {
        "command": "codebookmark.bookmark.searchInFile",
        "title": "当前文件内搜索",
        "icon": "$(search)",
        "enablement": "bookmarks.var.bookmark.hasBookmark",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.toggleExpandCollapse",
        "title": "展开书签节点",
        "icon": "$(expand-all)",
        "enablement": "bookmarks.var.bookmark.hasBookmark",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.collapseToLevel",
        "title": "折叠书签节点",
        "icon": "$(collapse-all)",
        "enablement": "bookmarks.var.bookmark.hasBookmark",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.bookmark.sort",
        "title": "$(list-selection) 排序模式",
        "icon": "$(list-selection)",
        "enablement": "bookmarks.var.bookmark.hasBookmark",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.openSettings",
        "title": "$(settings) 打开代码书签设置",
        "icon": "$(settings)",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.openHelp",
        "title": "$(info) 使用说明",
        "icon": "$(info)",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateAppend",
        "title": "$(add) 追加",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateOverwrite",
        "title": "$(replace) 替换",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateSkip",
        "title": "$(diff-added) 生成",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.optimize",
        "title": "$(hubot) 单文件",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.optimizeSelected",
        "title": "$(hubot) 选中项",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateAppendFolder",
        "title": "$(add) 追加",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateOverwriteFolder",
        "title": "$(replace) 替换",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.generateSkipFolder",
        "title": "$(diff-added) 生成",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.optimizeFolder",
        "title": "$(hubot) 文件夹"
      },
      {
        "command": "codebookmark.ai.optimizeContextItem",
        "title": "$(hubot) AI 优化书签标签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.ai.testConnection",
        "title": "Test AI Connection",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.exportToMarkdown",
        "title": "$(export) 导出书签为 Markdown 报表",
        "enablement": "bookmarks.var.bookmark.hasBookmark",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.clearInvalidBookmarks",
        "title": "$(trash) 清除失效书签",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.undo",
        "title": "撤销",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo",
        "title": "恢复",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.drag",
        "title": "撤销上一步操作 (拖拽节点位置)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.drag",
        "title": "恢复撤销的操作 (拖拽节点位置)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.add",
        "title": "撤销上一步操作 (新增书签)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.add",
        "title": "恢复撤销的操作 (新增书签)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.delete",
        "title": "撤销上一步操作 (删除书签)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.delete",
        "title": "恢复撤销的操作 (删除书签)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.sync",
        "title": "撤销上一步操作 (同步代码变更)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.sync",
        "title": "恢复撤销的操作 (同步代码变更)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.rename",
        "title": "撤销上一步操作 (重命名书签)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.rename",
        "title": "恢复撤销的操作 (重命名书签)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.icon",
        "title": "撤销上一步操作 (修改书签图标)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.icon",
        "title": "恢复撤销的操作 (修改书签图标)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.move",
        "title": "撤销上一步操作 (移动书签层级)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.move",
        "title": "恢复撤销的操作 (移动书签层级)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.status",
        "title": "撤销上一步操作 (更改展开状态)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.status",
        "title": "恢复撤销的操作 (更改展开状态)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.ai",
        "title": "撤销上一步操作 (AI 批量生成书签)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.ai",
        "title": "恢复撤销的操作 (AI 批量生成书签)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      },
      {
        "command": "codebookmark.undo.ai-optimize",
        "title": "撤销上一步操作 (AI 批量优化标签)",
        "icon": "$(discard)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canUndo"
      },
      {
        "command": "codebookmark.redo.ai-optimize",
        "title": "恢复撤销的操作 (AI 批量优化标签)",
        "icon": "$(redo)",
        "category": "Code Bookmarks",
        "enablement": "bookmarks.var.bookmark.canRedo"
      }
    ],
    "keybindings": [
      {
        "command": "codebookmark.deleteBookmark",
        "key": "delete",
        "when": "listFocus && (focusedView == 'codebookmarkTreeView' || focusedView == 'codebookmarkWatcherTree')"
      },
      {
        "command": "codebookmark.renameBookmark",
        "title": "重命名书签",
        "key": "f2",
        "when": "listFocus && (focusedView == 'codebookmarkTreeView' || focusedView == 'codebookmarkWatcherTree')",
        "category": "Code Bookmarks"
      },
      {
        "command": "codebookmark.toggleBookmark",
        "title": "添加/删除书签",
        "key": "ctrl+b",
        "category": "Code Bookmarks",
        "when": "editorTextFocus"
      },
      {
        "command": "codebookmark.forceAddBookmark",
        "title": "强制添加书签",
        "key": "ctrl+alt+shift+b",
        "category": "Code Bookmarks",
        "when": "editorTextFocus"
      },
      {
        "command": "codebookmark.forceDeleteBookmark",
        "title": "强制删除书签",
        "key": "ctrl+alt+shift+d",
        "category": "Code Bookmarks",
        "when": "editorTextFocus"
      },
      {
        "command": "workbench.view.extension.codebookmark",
        "key": "alt+b"
      }
    ],
    "menus": {
      "commandPalett": [
        {
          "command": "codebookmark.toggleBookmark"
        },
        {
          "command": "codebookmark.forceAddBookmark"
        },
        {
          "command": "codebookmark.forceDeleteBookmark"
        },
        {
          "command": "codebookmark.ai.testConnection"
        }
      ],
      "view/title": [
        {
          "when": "(view == codebookmarkTreeView)",
          "group": "navigation@3",
          "submenu": "codebookmark.aiSubmenu"
        },
        {
          "when": "(view == codebookmarkTreeView)",
          "group": "navigation@4",
          "command": "codebookmark.bookmark.searchInFile"
        },
        {
          "when": "(view == codebookmarkTreeView) && !codebookmark.var.isExpanded",
          "group": "navigation@5",
          "command": "codebookmark.toggleExpandCollapse"
        },
        {
          "when": "(view == codebookmarkTreeView) && codebookmark.var.isExpanded",
          "group": "navigation@5",
          "command": "codebookmark.collapseToLevel"
        },
        {
          "when": "(view == codebookmarkTreeView)",
          "group": "navigation@99",
          "submenu": "codebookmark.moreSubmenu"
        },
        {
          "command": "codebookmark.undo",
          "when": "view == codebookmarkTreeView && !codebookmark.undoAction",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo",
          "when": "view == codebookmarkTreeView && !codebookmark.redoAction",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.drag",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'drag'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.drag",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'drag'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.add",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'add'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.add",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'add'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.delete",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'delete'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.delete",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'delete'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.sync",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'sync'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.sync",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'sync'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.rename",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'rename'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.rename",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'rename'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.icon",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'icon'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.icon",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'icon'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.move",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'move'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.move",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'move'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.status",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'status'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.status",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'status'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.ai",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'ai'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.ai",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'ai'",
          "group": "navigation@2"
        },
        {
          "command": "codebookmark.undo.ai-optimize",
          "when": "view == codebookmarkTreeView && codebookmark.undoAction == 'ai-optimize'",
          "group": "navigation@1"
        },
        {
          "command": "codebookmark.redo.ai-optimize",
          "when": "view == codebookmarkTreeView && codebookmark.redoAction == 'ai-optimize'",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "codebookmark.pinView",
          "title": "设为新书签上级节点",
          "icon": "$(folder-opened)",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && (viewItem == bookmark || viewItem == watcher) ",
          "group": "inline@2"
        },
        {
          "command": "codebookmark.unpinView",
          "title": "取消新书签上级节点",
          "icon": "$(folder)",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && viewItem == bookmarkPinned",
          "group": "inline@2"
        },
        {
          "submenu": "codebookmark.editSubmenu",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && (viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkPinned || viewItem == bookmarkInvalid)",
          "group": "inline@3"
        },
        {
          "command": "codebookmark.deleteBookmark",
          "title": "删除",
          "icon": "$(trash)",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && ((viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkInvalid)  || viewItem == bookmarkPinned)",
          "group": "inline@4"
        },
        {
          "command": "codebookmark.editBookmark.editLabel",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && ((viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkInvalid)  || viewItem == bookmarkPinned)",
          "group": "1_edit@1"
        },
        {
          "command": "codebookmark.editBookmark.changeIcon",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && ((viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkInvalid)  || viewItem == bookmarkPinned)",
          "group": "1_edit@2"
        },
        {
          "command": "codebookmark.editBookmark.restoreDefaultIcon",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && ((viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkInvalid)  || viewItem == bookmarkPinned)",
          "group": "1_edit@3"
        },
        {
          "command": "codebookmark.ai.optimizeContextItem",
          "when": "((view == codebookmarkTreeView) || (view == codebookmarkWatcherTree)) && ((viewItem == bookmark || viewItem == watcher || viewItem == bookmarkFolder || viewItem == bookmarkInvalid)  || viewItem == bookmarkPinned)",
          "group": "1_edit@4"
        }
      ],
      "editor/context": [
        {
          "command": "codebookmark.toggleBookmark",
          "group": "codebookmark@1",
          "when": "editorTextFocus"
        },
        {
          "command": "codebookmark.forceAddBookmark",
          "group": "codebookmark@2",
          "when": "editorTextFocus"
        },
        {
          "command": "codebookmark.forceDeleteBookmark",
          "group": "codebookmark@3",
          "when": "editorTextFocus"
        }
      ],
      "codebookmark.editSubmenu": [
        {
          "command": "codebookmark.editBookmark.editLabel",
          "when": "viewItem != bookmarkInvalid",
          "group": "1_modification@1"
        },
        {
          "command": "codebookmark.editBookmark.changeIcon",
          "when": "viewItem != bookmarkInvalid",
          "group": "1_modification@2"
        },
        {
          "command": "codebookmark.editBookmark.updatePosOnly",
          "group": "2_position@1"
        },
        {
          "command": "codebookmark.editBookmark.updatePosAndRename",
          "group": "2_position@2"
        }
      ],
      "codebookmark.moreSubmenu": [
        {
          "command": "codebookmark.clearInvalidBookmarks",
          "group": "0_clear@1",
          "when": "bookmarks.var.bookmark.hasInvalid"
        },
        {
          "command": "codebookmark.bookmark.sort",
          "group": "1_primary@1"
        },
        {
          "command": "codebookmark.exportToMarkdown",
          "group": "1_primary@2"
        },
        {
          "command": "codebookmark.openHelp",
          "group": "2_secondary@1"
        },
        {
          "command": "codebookmark.openSettings",
          "group": "2_secondary@2"
        }
      ],
