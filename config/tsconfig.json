{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2020",
		"lib": ["es2022"],
		"outDir": "../out",
		"sourceMap": true,
		"rootDir": "../src",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": [
		"../src/**/*.ts"
	],
	"exclude": [
		"../node_modules",
		"../.vscode-test",
		"../tests"
	]
}
